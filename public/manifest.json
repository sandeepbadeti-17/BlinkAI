{
  "manifest_version": 3,
  "name": "BlinkAI",
  "version": "2.0",
  "description": "Select text anywhere — summarize, explain, and chat with AI instantly.",

  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "webNavigation",
    "tabs"
  ],

  "host_permissions": [
    "https://*/*",
    "http://*/*",
    "file:///*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*", "file:///*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "action": {
    "default_title": "BlinkAI",
    "default_popup": "popup.html"
  },

  "web_accessible_resources": [
    {
      "resources": ["assets/*", "chunks/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
